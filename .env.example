# Environment
NODE_ENV=development

# Server Configuration
PORT=3000
HOST=0.0.0.0

# API Configuration
API_PREFIX=/api
API_VERSION=v1

# Logging
LOG_LEVEL=info

# Database (PostgreSQL for all environments)
# Development: PostgreSQL container on port 5432
# Testing: PostgreSQL container on port 5433
# Production: External PostgreSQL service (configured via environment)
DATABASE_URL=postgresql://developer:password@localhost:5432/fantasy_character_api_dev

# Security - Authentication
# IMPORTANT: Change JWT_SECRET in production!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-64-chars-long
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Argon2 Password Hashing Configuration
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# RBAC Control (Role-Based Access Control)
# false: Disable for development/testing
# true: Enable for production
RBAC_ENABLED=false

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_TIMEWINDOW=60000

# CORS (Cross-Origin Resource Sharing)
CORS_ORIGIN=http://localhost:3000

# Health Check
HEALTH_CHECK_ENABLED=true

# Caching Configuration
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=300
CACHE_MAX_ENTRIES=1000

# OAuth Configuration (optional - for social login)
# Uncomment and configure these for OAuth support
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# Session Management (for OAuth flows)
# Required if using OAuth - must be at least 32 characters
# SESSION_SECRET=your-session-secret-for-oauth-minimum-64-chars-long

# Production Notes:
# - All values above are development defaults
# - In production, override via environment variables or external configuration
# - Use strong, unique secrets for JWT_SECRET and SESSION_SECRET (minimum 64 characters)
# - Set DATABASE_URL to your production PostgreSQL instance
# - Configure CORS_ORIGIN with your actual frontend domains (avoid * in production)
# - Enable RBAC_ENABLED=true for production security
# - Use environment-specific values for all sensitive configurations
# - Consider using external secret management services in production
