{
    "name": "fantasy-character-api",
    "version": "1.0.0",
    "description": "A comprehensive RESTful API designed for managing fantasy characters",
    "license": "MIT",
    "author": "Antonio Colagreco",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "build": "tsc",
        "dev": "tsx watch src/index.ts",
        "start": "node dist/index.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "format": "prettier --write src/**/*.ts",
        "format:check": "prettier --check src/**/*.ts",
        "clean": "rimraf dist",
        "prebuild": "pnpm run clean",
        "docker:build": "docker build -t fantasy-character-api .",
        "docker:run": "docker run -p 3000:3000 fantasy-character-api",
        "docker:dev": "docker build -f Dockerfile.dev -t fantasy-character-api:dev . && docker run -p 3000:3000 -v $(pwd):/app fantasy-character-api:dev",
        "prisma:generate": "prisma generate",
        "prisma:reset": "prisma migrate reset --force",
        "prisma:migrate": "prisma migrate dev --name init",
        "prisma:seed": "prisma db seed",
        "prisma:studio": "prisma studio"
    },
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    },
    "keywords": [
        "fantasy",
        "character",
        "api",
        "fastify",
        "typescript",
        "prisma",
        "game",
        "rpg"
    ],
    "engines": {
        "node": ">=24.0.0",
        "pnpm": ">=9.0.0"
    },
    "dependencies": {
        "@fastify/helmet": "^12.0.1",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/sensible": "^6.0.3",
        "@fastify/swagger": "^9.5.1",
        "@fastify/swagger-ui": "^5.2.3",
        "@prisma/client": "^6.13.0",
        "@sinclair/typebox": "^0.33.22",
        "ajv": "^8.17.1",
        "fastify": "^5.4.0",
        "pino": "^9.7.0",
        "pino-pretty": "^11.3.0",
        "prisma": "^6.13.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.32.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.17.0",
        "@typescript-eslint/eslint-plugin": "^8.39.0",
        "@typescript-eslint/parser": "^8.39.0",
        "eslint": "^9.32.0",
        "eslint-config-prettier": "^9.1.2",
        "eslint-plugin-filenames": "^1.3.2",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-prettier": "^5.5.3",
        "eslint-plugin-unicorn": "^60.0.0",
        "jest": "^29.7.0",
        "prettier": "^3.6.2",
        "rimraf": "^6.0.1",
        "supertest": "^7.1.4",
        "ts-jest": "^29.4.1",
        "tsx": "^4.20.3",
        "typescript": "^5.9.2"
    },
    "packageManager": "pnpm@10.14.0"
}
