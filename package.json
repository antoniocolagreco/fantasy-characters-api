{
  "name": "fantasy-character-api",
  "version": "1.0.0",
  "description": "A comprehensive RESTful API designed for managing fantasy characters",
  "license": "MIT",
  "author": "Antonio Colagreco",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:enforce": "pnpm run test:coverage && node scripts/check-coverage.mjs",
    "test:ui": "vitest --ui",
    "lint": "eslint ./**/*.ts",
    "lint:fix": "eslint ./**/*.ts --fix",
    "lint:md": "markdownlint docs/**/*.md",
    "lint:md:fix": "markdownlint --fix docs/**/*.md",
    "format": "prettier --write ./**/*.{ts,js,jsx,tsx,json,md,yml,yaml}",
    "format:check": "prettier --check ./**/*.{ts,js,jsx,tsx,json,md,yml,yaml}",
    "format:md": "prettier --write \"docs/**/*.md\"",
    "clean": "rimraf dist",
    "prebuild": "pnpm run clean",
    "docker:build": "docker build -t fantasy-character-api .",
    "docker:run": "docker run -p 3000:3000 fantasy-character-api",
    "docker:dev": "docker build -f Dockerfile.dev -t fantasy-character-api:dev . && docker run -p 3000:3000 -v $(pwd):/app fantasy-character-api:dev",
    "prisma:generate": "prisma generate",
    "prisma:reset": "prisma migrate reset --force",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio"
  },
  "keywords": [
    "fantasy",
    "character",
    "api",
    "fastify",
    "typescript",
    "prisma",
    "game",
    "rpg"
  ],
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/oauth2": "^8.1.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/session": "^11.1.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@prisma/client": "^6.13.0",
    "@sinclair/typebox": "^0.33.22",
    "ajv": "^8.17.1",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.1",
    "fastify": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.7.0",
    "pino-pretty": "^11.3.0",
    "prisma": "^6.13.0",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.17.0",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-filenames": "^1.3.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-unicorn": "^60.0.0",
    "markdownlint-cli": "^0.45.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.14.0",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
